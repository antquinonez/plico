{
  "company": "Far Finer LLC",
  "product": "FFClients",
  "version": "1.1.0",
  "release_date": "2024-06-15",
  "features": {
    "orchestrator": {
      "enabled": true,
      "max_concurrency": 10,
      "default_retries": 3
    },
    "document_processing": {
      "enabled": true,
      "cache_dir": "doc_cache",
      "checksum_length": 8
    },
    "batch_mode": {
      "enabled": true,
      "output_modes": ["combined", "separate_sheets"]
    }
  },
  "supported_providers": [
    "mistral",
    "anthropic",
    "openai",
    "azure",
    "gemini"
  ],
  "dependencies": {
    "python": ">=3.10",
    "polars": ">=1.0.0",
    "openpyxl": ">=3.0.0"
  }
}
