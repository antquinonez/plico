    default_model: "open-mixtral-8x7b"

  litellm-open-mixtral-8x22b:
    client_class: "FFLiteLLMClient"
    type: "litellm"
    provider_prefix: "mistral/"
    api_key_env: "MISTRAL_API_KEY"
