  # ╚═══════════════════════════════════════════════════════════════════════════╝

  # gemini:
  #   type: "native"
  #   client_class: "FFGemini"
  #   api_key_env: "GOOGLE_APPLICATION_CREDENTIALS"


  # ╔═══════════════════════════════════════════════════════════════════════════╗
  # ║  PERPLEXITY AI                                                            ║
  # ╠═══════════════════════════════════════════════════════════════════════════╣
  # ║  Sonar models via Perplexity API                                          ║
  # ╚═══════════════════════════════════════════════════════════════════════════╝

  # perplexity:
  #   type: "native"
  #   client_class: "FFPerplexity"
