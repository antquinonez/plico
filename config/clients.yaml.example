    client_class: "FFLiteLLMClient"
    type: "litellm"
    provider_prefix: "anthropic/"
    api_key_env: "ANTHROPIC_API_KEY"
    default_model: "claude-3-5-sonnet-20241022"

  litellm-claude-3-5-haiku:
    client_class: "FFLiteLLMClient"
    type: "litellm"
