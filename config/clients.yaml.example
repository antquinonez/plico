  # ╔═══════════════════════════════════════════════════════════════════════════╗
  # ║  LITELLM UNIFIED ROUTING                                                  ║
  # ╠═══════════════════════════════════════════════════════════════════════════╣
  # ║  Use LiteLLM for unified API access to multiple providers.                ║
  # ║  Provider prefixes route to correct API:                                  ║
  # ║    - "mistral/"     → Mistral AI                                          ║
  # ║    - "anthropic/"   → Anthropic                                           ║
  # ║    - "openai/"      → OpenAI                                              ║
  # ║    - "azure/"       → Azure OpenAI                                        ║
  # ║    - "gemini/"      → Google Gemini                                       ║
  # ║    - "perplexity/"  → Perplexity                                          ║
  # ║    - "nvidia_nim/"  → NVIDIA NIM                                          ║
  # ╚═══════════════════════════════════════════════════════════════════════════╝

  # ── LiteLLM Generic ────────────────────────────────────────────────────────
  # litellm:
  #   type: "litellm"
  #   provider_prefix: ""
  #   api_key_env: "LITELLM_API_KEY"

  # ── LiteLLM + Mistral ───────────────────────────────────────────────────────
  # litellm-mistral:
  #   type: "litellm"
  #   provider_prefix: "mistral/"
  #   api_key_env: "MISTRAL_API_KEY"

  # ── LiteLLM + Anthropic ─────────────────────────────────────────────────────
  # litellm-anthropic:
  #   type: "litellm"
  #   provider_prefix: "anthropic/"
  #   api_key_env: "ANTHROPIC_API_KEY"

  # ── LiteLLM + OpenAI ────────────────────────────────────────────────────────
  # litellm-openai:
  #   type: "litellm"
  #   provider_prefix: "openai/"
  #   api_key_env: "OPENAI_API_KEY"

  # ── LiteLLM + Azure OpenAI ──────────────────────────────────────────────────
  # litellm-azure:
  #   type: "litellm"
  #   provider_prefix: "azure/"
  #   api_key_env: "AZURE_API_KEY"
  #   # api_base: "https://your-instance.openai.azure.com/"
  #   # api_version: "2024-02-15-preview"

  # ── LiteLLM + Google Gemini ─────────────────────────────────────────────────
  # litellm-gemini:
  #   type: "litellm"
  #   provider_prefix: "gemini/"
  #   api_key_env: "GEMINI_API_KEY"

  # ── LiteLLM + Perplexity ────────────────────────────────────────────────────
  # litellm-perplexity:
  #   type: "litellm"
  #   provider_prefix: "perplexity/"
  #   api_key_env: "PERPLEXITY_API_KEY"


