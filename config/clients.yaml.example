# FFClients AI Client Configuration - Example
# ============================================
# This file shows all available LiteLLM clients and native clients.
# Copy relevant entries to clients.yaml and uncomment/configure as needed.
#
# Configuration Options:
#   type:           - "litellm" (unified routing) or "native" (direct API client)
#   provider_prefix - LiteLLM provider prefix (e.g., "anthropic/", "azure/")
#   api_key_env     - Environment variable name containing the API key
#   api_key         - Direct API key (optional, takes precedence over api_key_env)
#   client_class    - Native client class (for type: "native" only)
#   azure_endpoint  - Azure endpoint URL (for Azure native clients)
#   azure_deployment - Azure deployment name (for Azure native clients)

clients:
  # ╔═══════════════════════════════════════════════════════════════════════════╗
  # ║  MISTRAL AI (Direct API)                                                  ║
  # ╠═══════════════════════════════════════════════════════════════════════════╣
  # ║  Native Mistral clients using mistralai library                           ║
  # ╚═══════════════════════════════════════════════════════════════════════════╝

  # mistral:
  #   type: "native"
  #   client_class: "FFMistral"
  #   api_key_env: "MISTRAL_KEY"

  # mistral-small:
  #   type: "native"
  #   client_class: "FFMistralSmall"
  #   api_key_env: "MISTRALSMALL_KEY"


  # ╔═══════════════════════════════════════════════════════════════════════════╗
  # ║  ANTHROPIC                                                                ║
  # ╠═══════════════════════════════════════════════════════════════════════════╣
  # ║  Claude models via Anthropic API                                          ║
  # ╚═══════════════════════════════════════════════════════════════════════════╝

  # anthropic:
  #   type: "native"
  #   client_class: "FFAnthropic"
  #   api_key_env: "ANTHROPIC_TOKEN"

  # anthropic-cached:
  #   type: "native"
  #   client_class: "FFAnthropicCached"
  #   api_key_env: "ANTHROPIC_TOKEN"


  # ╔═══════════════════════════════════════════════════════════════════════════╗
  # ║  GOOGLE GEMINI                                                            ║
  # ╠═══════════════════════════════════════════════════════════════════════════╣
