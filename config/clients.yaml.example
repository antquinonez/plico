# FFClients Client Types Configuration - Example
# ===============================================
# This file shows all available client types with their default models.
# Copy the client types you need to clients.yaml and configure as needed.
#
# API keys should be set via environment variables (see api_key_env field).
#
# Structure:
#   default_client: Name of the client type to use by default
#   client_types: Dictionary of client type configurations
#
# Each client_type has:
#   client_class: The Python class name (e.g., "FFLiteLLMClient", "FFMistralSmall")
#   type: Either "native" (direct API) or "litellm" (via LiteLLM routing)
#   api_key_env: Environment variable name for the API key
#   provider_prefix: LiteLLM provider prefix (only for type: litellm)
#   default_model: Default model identifier

default_client: "litellm-mistral-small"

client_types:
  # ===========================================
  # NATIVE CLIENTS (Direct API, no LiteLLM)
  # ===========================================

  mistral-small:
    client_class: "FFMistralSmall"
    type: "native"
    api_key_env: "MISTRALSMALL_KEY"
    default_model: "mistral-small-2503"

  mistral:
    client_class: "FFMistral"
    type: "native"
    api_key_env: "MISTRAL_API_KEY"
    default_model: "mistral-large-latest"

  anthropic:
    client_class: "FFAnthropic"
    type: "native"
    api_key_env: "ANTHROPIC_TOKEN"
    default_model: "claude-3-5-sonnet-20241022"

  anthropic-cached:
    client_class: "FFAnthropicCached"
    type: "native"
    api_key_env: "ANTHROPIC_TOKEN"
    default_model: "claude-3-5-sonnet-20241022"

  gemini:
    client_class: "FFGemini"
    type: "native"
    api_key_env: "GEMINI_API_KEY"
    default_model: "gemini-1.5-pro"

  perplexity:
    client_class: "FFPerplexity"
    type: "native"
    api_key_env: "PERPLEXITY_API_KEY"
    default_model: "llama-3.1-sonar-large-128k-online"

  openai-assistant:
    client_class: "FFOpenAIAssistant"
    type: "native"
    api_key_env: "OPENAI_API_KEY"
    default_model: "gpt-4-turbo"

  nvidia-deepseek:
    client_class: "FFNvidiaDeepSeek"
    type: "native"
    api_key_env: "NVIDIA_API_KEY"
    default_model: "deepseek-ai/deepseek-r1"

  # Azure native clients
  azure-mistral:
    client_class: "FFAzureMistral"
    type: "native"
    api_key_env: "AZURE_API_KEY"
    default_model: "mistral-large"

  azure-mistral-small:
    client_class: "FFAzureMistralSmall"
    type: "native"
    api_key_env: "AZURE_API_KEY"
    default_model: "mistral-small"

  azure-codestral:
    client_class: "FFAzureCodestral"
    type: "native"
    api_key_env: "AZURE_API_KEY"
    default_model: "codestral"

  azure-deepseek:
    client_class: "FFAzureDeepSeek"
    type: "native"
    api_key_env: "AZURE_API_KEY"
    default_model: "deepseek-r1"

  azure-deepseek-v3:
    client_class: "FFAzureDeepSeekV3"
    type: "native"
    api_key_env: "AZURE_API_KEY"
    default_model: "deepseek-v3"

  azure-ms-deepseek-r1:
    client_class: "FFAzureMSDeepSeekR1"
    type: "native"
    api_key_env: "AZURE_API_KEY"
    default_model: "DeepSeek-R1"

  azure-phi:
    client_class: "FFAzurePhi"
    type: "native"
    api_key_env: "AZURE_API_KEY"
    default_model: "phi-4"

  # ===========================================
  # LITELLM CLIENTS - MISTRAL
  # ===========================================

  litellm-mistral-small:
    client_class: "FFLiteLLMClient"
    type: "litellm"
    provider_prefix: "mistral/"
    api_key_env: "MISTRAL_API_KEY"
    default_model: "mistral-small-latest"

  litellm-mistral-medium:
    client_class: "FFLiteLLMClient"
    type: "litellm"
    provider_prefix: "mistral/"
    api_key_env: "MISTRAL_API_KEY"
    default_model: "mistral-medium-latest"

  litellm-mistral-large:
    client_class: "FFLiteLLMClient"
    type: "litellm"
    provider_prefix: "mistral/"
    api_key_env: "MISTRAL_API_KEY"
    default_model: "mistral-large-latest"

  litellm-codestral:
    client_class: "FFLiteLLMClient"
    type: "litellm"
    provider_prefix: "mistral/"
    api_key_env: "MISTRAL_API_KEY"
    default_model: "codestral-latest"

  litellm-open-mistral-7b:
    client_class: "FFLiteLLMClient"
    type: "litellm"
    provider_prefix: "mistral/"
    api_key_env: "MISTRAL_API_KEY"
    default_model: "open-mistral-7b"

  litellm-open-mixtral-8x7b:
